{
  "manifest_version": 3,
  "name": "FB Contest Helper",
  "short_name": "FB Helper",
  "version": "1.2.1",
  "description": "Automatisez vos tags de concours sur Facebook de manière intelligente et sécurisée.",
  "author": "Lemlijn Clément",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://www.facebook.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Ouvrir FB Contest Helper"
  }
}